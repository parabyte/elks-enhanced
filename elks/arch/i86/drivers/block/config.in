#
# Block device driver configuration
#
mainmenu_option next_comment
    comment 'Block device drivers'

	bool '  BIOS floppy drive support'	CONFIG_BLK_DEV_BFD	y
	bool '  Direct hw floppy support'	CONFIG_BLK_DEV_FD	n
	bool '  Floppy drive track caching'	CONFIG_TRACK_CACHE	y
	bool '  BIOS preset floppy types'	CONFIG_BLK_DEV_BFD_HARD n
	bool '  BIOS hard drive support'	CONFIG_BLK_DEV_BHD	y
	bool '  IDE hard drive CHS probe'	CONFIG_IDE_PROBE	y
	if [ "$CONFIG_BLK_DEV_FD" == "y" ]; then
		define_bool CONFIG_ASYNCIO y
	fi

	comment 'Additional block devices'

	bool 'RAM disk support'			CONFIG_BLK_DEV_RAM	y
	if [ "$CONFIG_BLK_DEV_RAM" == "y" ]; then
		hex 'Preload RAM disk segment address' CONFIG_RAMDISK_SEGMENT 0
		int 'Preload RAM disk sectors' CONFIG_RAMDISK_SECTORS 128
	fi
	choice 'SSD disk driver' \
		"None CONFIG_BLK_DEV_SSD_NONE \
		Test CONFIG_BLK_DEV_SSD_TEST \
		SDCard CONFIG_BLK_DEV_SSD_SD" None

	if [ "$CONFIG_BLK_DEV_SSD_SD" == "y" ] && [ "$CONFIG_ARCH_NECV25" == "y" ]; then
      bool 'Interface SD card with hardware SPI'	CONFIG_HW_SPI	y
	fi

	bool 'ATA-CF/IDE drive support'	        CONFIG_BLK_DEV_ATA_CF	n
	if [ "$CONFIG_BLK_DEV_ATA_CF" == "y" ]; then
		int '  ATA/XTIDE default mode (-1 auto, 0 ATA, 1 XTIDEv1, 2 XTIDEv2, 3 XTCF, 4 SOLO86)' CONFIG_ATA_MODE_DEFAULT -1
		hex '  Standard ATA base I/O port' CONFIG_ATA_BASE_PORT 0x1F0
		hex '  XTIDE/XTCF base I/O port' CONFIG_ATA_XTIDE_BASE_PORT 0x300
		hex '  SOLO/86 ATA base I/O port' CONFIG_ATA_SOLO86_BASE_PORT 0x40
		bool '  ATAPI CD-ROM packet support' CONFIG_ATA_ATAPI y
		bool '  Flush ATA write cache on final close' CONFIG_ATA_FLUSH_CACHE y
	fi

	bool 'XT MFM hard drive support' CONFIG_BLK_DEV_MFMHD n
	if [ "$CONFIG_BLK_DEV_MFMHD" == "y" ]; then
		hex '  Primary MFM I/O port' CONFIG_MFMHD_PRIMARY_PORT 0x320
		hex '  Secondary MFM I/O port' CONFIG_MFMHD_SECONDARY_PORT 0x324
		int '  MFM drives to probe' CONFIG_MFMHD_ACTIVE_DRIVES 2
		choice '  MFM controller profile' \
			"WD1002A-WX1 CONFIG_MFMHD_CTRL_WD1002 \
			Seagate-ST11-FileCard CONFIG_MFMHD_CTRL_SEAGATE" WD1002A-WX1
		if [ "$CONFIG_MFMHD_CTRL_WD1002" == "y" ]; then
			choice '  WD1002A-WX1 BIOS geometry table' \
				"Super CONFIG_MFMHD_BIOS_SUPER \
				G CONFIG_MFMHD_BIOS_G \
				H CONFIG_MFMHD_BIOS_H" Super
		fi
		int '  Command step-rate code' CONFIG_MFMHD_STEP_CODE 0
		int '  Drive 0 cylinders override (0 uses controller)' CONFIG_MFMHD_DRIVE0_CYLINDERS 0
		int '  Drive 0 heads override (0 uses controller)' CONFIG_MFMHD_DRIVE0_HEADS 0
		int '  Drive 0 sectors override (0 uses controller)' CONFIG_MFMHD_DRIVE0_SECTORS 0
		int '  Drive 1 cylinders override (0 uses controller)' CONFIG_MFMHD_DRIVE1_CYLINDERS 0
		int '  Drive 1 heads override (0 uses controller)' CONFIG_MFMHD_DRIVE1_HEADS 0
		int '  Drive 1 sectors override (0 uses controller)' CONFIG_MFMHD_DRIVE1_SECTORS 0
		bool '  Maintenance ioctls (diagnostic/format/control)' CONFIG_MFMHD_DIAG_IOCTLS n
		bool '  Trace MFM command handshakes' CONFIG_MFMHD_TRACE n
	fi

    comment 'Block device options'
    bool 'Character access to block devices'	CONFIG_BLK_DEV_CHAR	y
endmenu
